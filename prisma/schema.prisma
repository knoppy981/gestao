// Prisma schema — MongoDB, infra only (no models defined yet).
// Docs: https://pris.ly/d/prisma-schema
// MongoDB stays on Prisma 6.x with the classic `prisma-client-js` generator.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
